{
  "name": "idctl",
  "version": "0.1.625",
  "description": "ID Agents Control Center — a standalone reactive terminal app for the id-agents manager (live fleet dashboard + conversational manager chat + full lifecycle control).",
  "type": "module",
  "private": true,
  "bin": {
    "idctl": "./bin/idctl.mjs"
  },
  "scripts": {
    "prestart": "node build/gen-version.mjs",
    "start": "tsx src/cli.tsx",
    "predev": "node build/gen-version.mjs",
    "dev": "tsx watch src/cli.tsx",
    "status": "tsx src/cli.tsx status",
    "typecheck": "tsc --noEmit",
    "build:bin": "node build/gen-version.mjs && bun build/build.mjs",
    "build:app": "bash build/make-app.sh",
    "build:sums": "cd dist && shasum -a 256 idctl-* > SHASUMS256.txt",
    "build:mjs": "esbuild src/cli.tsx --bundle --platform=node --target=node20 --format=esm --outfile=dist/idctl.mjs --banner:js=\"import{createRequire as ___cr}from'module';const require=___cr(import.meta.url);\" --jsx=automatic",
    "test": "tsx src/api/onboard.test.ts && tsx src/api/teamDesign.test.ts && tsx src/api/skillTags.test.ts && tsx src/api/managerNormalization.test.ts && tsx src/api/tasksByStatus.test.ts && tsx src/settings/providerCatalog.test.ts && tsx src/settings/localDiscovery.test.ts && tsx src/settings/runtimeCatalog.test.ts",
    "smoke": "tsx src/__smoke__/render-smoke.tsx",
    "smoke:dispatch": "tsx src/__smoke__/dispatch-smoke.ts",
    "smoke:providers": "tsx src/__smoke__/provider-smoke.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ink": "^5.1.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1",
    "react-devtools-core": "file:build/react-devtools-core-stub"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "@types/react": "^18.3.12",
    "esbuild": "^0.28.1",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
