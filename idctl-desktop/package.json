{
  "name": "idagents-control-center",
  "productName": "ID Agents Control Center",
  "version": "0.1.565",
  "description": "Desktop control center for id-agents — live fleet dashboard, manager chat, teams, keys.",
  "private": true,
  "main": "out/main/main.cjs",
  "scripts": {
    "build": "node scripts/build.mjs",
    "start": "npm run build && electron .",
    "dev": "node scripts/build.mjs && electron .",
    "dist": "npm run build && electron-builder --dir",
    "dmg": "npm run build && electron-builder",
    "typecheck": "tsc --noEmit",
    "test:context-budget": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/context-budget-smoke.mjs",
    "test:context-history": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/context-budget-history.mjs",
    "test:headroom-plugin": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/headroom-plugin-path-smoke.mjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "node scripts/build-tauri.mjs && tauri build"
  },
  "build": {
    "appId": "world.idchain.idagents-control",
    "productName": "ID Agents Control Center",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "node_modules/@nut-tree-fork/libnut-darwin/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*"
    ],
    "asarUnpack": [
      "**/*.node",
      "node_modules/@nut-tree-fork/**"
    ],
    "extraResources": [
      {
        "from": "resources/computeruse-mcp",
        "to": "computeruse-mcp"
      },
      {
        "from": "resources/idacc-context-retrieval",
        "to": "idacc-context-retrieval"
      },
      {
        "from": "../docs/CONTROL_CENTER_WIKI.json",
        "to": "docs/CONTROL_CENTER_WIKI.json"
      }
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools",
      "target": [
        "dir"
      ]
    }
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^22.19.21",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.28.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@noble/curves": "^1.9.1",
    "@noble/hashes": "^1.8.0",
    "@nut-tree-fork/libnut-darwin": "^2.7.5",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-http": "^2.5.9"
  }
}
