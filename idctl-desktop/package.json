{
  "name": "idagents-control-center",
  "productName": "ID Agents Control Center",
  "version": "0.1.673",
  "description": "Desktop control center for id-agents — live fleet dashboard, manager chat, teams, keys.",
  "private": true,
  "main": "out/main/main.cjs",
  "scripts": {
    "build": "node scripts/build.mjs",
    "start": "npm run build && electron .",
    "dev": "node scripts/build.mjs && electron .",
    "dist": "npm run build && electron-builder --dir",
    "dmg": "npm run build && electron-builder",
    "typecheck": "tsc --noEmit",
    "test:chat-failure": "node scripts/chat-terminal-failure-smoke.mjs",
    "test:background-policy": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/background-policy-smoke.mjs",
    "test:release-payload": "node ../scripts/release-payload-smoke.mjs",
    "test:release-cleanup": "node ../scripts/release-artifact-cleanup-smoke.mjs",
    "test:release-published": "node ../scripts/release-published-smoke.mjs",
    "test:signing-guardrails": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/signing-guardrails-smoke.mjs",
    "test:agent-wallet-lifecycle": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/agent-wallet-lifecycle-smoke.mjs",
    "test:walletconnect-bootstrap": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/walletconnect-bootstrap-smoke.mjs",
    "test:update-target-guard": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/update-target-guard-smoke.mjs",
    "test:manager-installer": "node ../scripts/install-id-agents-manager-smoke.mjs",
    "test:update-repo": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/update-repo-migration-smoke.mjs",
    "test:manager-updater": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/manager-updater-smoke.mjs",
    "test:team-provider-lanes": "node scripts/team-builder-provider-lanes-smoke.mjs",
    "test:capability-worker-scope": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/capability-worker-scope-smoke.mjs",
    "test:runtime-catalog-refresh": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/runtime-catalog-refresh-smoke.mjs",
    "test:safe-production-readiness": "node scripts/safe-production-readiness-smoke.mjs",
    "test:agent-signer-vault": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/agent-signer-vault-smoke.mjs",
    "test:safe-roles-execution": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/safe-roles-execution-smoke.mjs",
    "test:safe-roles-provider": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/safe-roles-provider-smoke.mjs",
    "test:alchemy-asset-inspector": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/alchemy-asset-inspector-smoke.mjs",
    "test:context-budget": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/context-budget-smoke.mjs",
    "test:context-history": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/context-budget-history.mjs",
    "test:dashboard-coordination": "node scripts/dashboard-coordination-roster-smoke.mjs",
    "test:dashboard-command-surface": "node scripts/dashboard-command-surface-smoke.mjs",
    "test:dashboard-activity-filter": "node scripts/dashboard-activity-filter-smoke.mjs",
    "test:activity-feed-actions": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/activity-feed-actions-smoke.mjs",
    "test:org-hierarchy": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/org-hierarchy-coordinator-smoke.mjs",
    "test:team-ops-fleet": "node scripts/team-ops-fleet-smoke.mjs",
    "test:team-structure-chart": "node scripts/team-structure-chart-smoke.mjs",
    "test:learn-context": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/learn-context-smoke.mjs",
    "test:learn-failure-display": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/learn-failure-display-smoke.mjs",
    "test:learn-task-automation": "node scripts/learn-task-automation-smoke.mjs",
    "test:goal-autopilot-fallback": "node scripts/goal-autopilot-fallback-smoke.mjs",
    "test:learn-brain-sync": "../idctl/node_modules/.bin/tsx scripts/learn-brain-sync-smoke.ts",
    "test:learn-queue": "../idctl/node_modules/.bin/tsx scripts/learn-queue-smoke.ts",
    "test:headroom-plugin": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/headroom-plugin-path-smoke.mjs",
    "test:goals-plan-separation": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/goals-plan-separation-smoke.mjs",
    "test:team-agent-groups": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/team-agent-groups-smoke.mjs",
    "test:plans-routing": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/plans-routing-smoke.mjs",
    "test:plans-inbox": "node scripts/plans-inbox-recovery-smoke.mjs",
    "test:plans-team-lead-delegation": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/plans-team-lead-delegation-smoke.mjs",
    "test:plans-work": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/plans-work-smoke.mjs",
    "test:work-delegation": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/work-delegation-smoke.mjs",
    "test:renderer-store": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/renderer-store-poll-smoke.mjs",
    "test:subs-cache": "node scripts/subs-status-cache-smoke.mjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "node scripts/build-tauri.mjs && tauri build"
  },
  "build": {
    "appId": "world.idchain.idagents-control",
    "productName": "ID Agents Control Center",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "node_modules/@nut-tree-fork/libnut-darwin/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*"
    ],
    "asarUnpack": [
      "**/*.node",
      "node_modules/@nut-tree-fork/**"
    ],
    "extraResources": [
      {
        "from": "resources/computeruse-mcp",
        "to": "computeruse-mcp"
      },
      {
        "from": "resources/idacc-context-retrieval",
        "to": "idacc-context-retrieval"
      },
      {
        "from": "../scripts/install-idacc-stack.mjs",
        "to": "scripts/install-idacc-stack.mjs"
      },
      {
        "from": "../scripts/install-id-agents-manager.mjs",
        "to": "scripts/install-id-agents-manager.mjs"
      }
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools",
      "target": [
        "dir"
      ]
    }
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^22.19.21",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.28.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@noble/curves": "^1.9.7",
    "@noble/hashes": "^1.8.0",
    "@nut-tree-fork/libnut-darwin": "^2.7.5",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-http": "^2.5.9",
    "@walletconnect/universal-provider": "^2.23.10",
    "ethers": "6.17.0",
    "qrcode": "^1.5.4"
  }
}
