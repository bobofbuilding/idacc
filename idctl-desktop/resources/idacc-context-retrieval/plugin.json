{
  "name": "idacc-context-retrieval",
  "version": "0.1.0",
  "description": "IDACC retrieval-handle resolver for future Headroom-backed context compression pilots.",
  "type": "local",
  "entrypoint": "SKILL.md",
  "idaccPortablePlugin": {
    "schemaVersion": 1,
    "neutral": true,
    "adapters": {
      "skill": {
        "entrypoint": "SKILL.md",
        "runtimes": ["claude-agent-sdk", "claude-code-cli", "claude-code-local", "codex", "cursor-cli", "grok", "antigravity", "gemini", "copilot", "kiro-cli", "q", "ollama"]
      },
      "mcp": {
        "command": "node",
        "args": ["tools/contract.mjs", "mcp"],
        "runtimes": ["claude-agent-sdk", "claude-code-cli", "claude-code-local", "codex", "grok", "gemini", "copilot", "kiro-cli", "q", "ollama"]
      },
      "nativePlugin": {
        "entrypoint": "SKILL.md",
        "runtimes": ["claude-agent-sdk", "claude-code-cli", "claude-code-local"]
      },
      "directFallback": {
        "runtimes": ["claude-agent-sdk", "claude-code-cli", "claude-code-local", "codex", "cursor-cli", "grok", "antigravity", "gemini", "copilot", "kiro-cli", "q", "ollama"],
        "mode": "send-original-context"
      }
    },
    "guardrails": [
      "Do not treat the native Claude plugin adapter as the only runtime path.",
      "Use MCP when a runtime can resolve tools, Skill instructions when it cannot, and direct fallback for unsupported or protected content.",
      "Never store secrets, auth material, wallet/key material, instruction sidecars, active patches, or validator evidence behind retrieval handles."
    ]
  },
  "scripts": [
    {
      "name": "contract",
      "command": "node tools/contract.mjs capabilities"
    },
    {
      "name": "resolve",
      "command": "node tools/contract.mjs resolve"
    },
    {
      "name": "mcp",
      "command": "node tools/contract.mjs mcp"
    }
  ]
}
